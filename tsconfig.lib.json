{
	"compilerOptions": {
		"target": "ES2021",
		"module": "CommonJS",
		"moduleResolution": "node",
		"lib": ["ES2021"],
		"baseUrl": "./",
		"rootDir": "./src",
		"outDir": "./dist",

		/* 1. Node.js 타입 에러 해결 (Buffer, stream 등) */
		"types": ["node"],
		"skipLibCheck": true,

		/* 2. 'e' is of type 'unknown' 에러 해결 */
		"useUnknownInCatchVariables": false,

		/* 3. dayjs 호출 에러 해결 */
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,

		/* 4. property has no initializer 에러 해결 */
		"strictPropertyInitialization": false,
		"declaration": true,
		"sourceMap": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"paths": {
			"@src/*": ["./src/*"],
			"@interfaces/*": ["./src/interfaces/*"],
			"@types/*": ["./src/types/*"],
			"@services/*": ["./src/services/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "test", "**/*.spec.ts"]
}
