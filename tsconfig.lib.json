{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"declaration": true,
		"emitDeclarationOnly": false,
		"sourceMap": true,
		"removeComments": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"paths": {
			"@src/*": ["./src/*"],
			"@interfaces/*": ["./src/interfaces/*"],
			"@types/*": ["./src/types/*"],
			"@services/*": ["./src/services/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "test", "**/*spec.ts"]
}
